{
  "name": "mithril-ui-kit",
  "version": "0.0.1",
  "description": "Mithril.js UI Component Library",
  "license": "MIT",
  "type": "module",
  "author": "K.Tsuru",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/14e28f87/mithril-ui-kit.git"
  },
  "homepage": "https://14e28f87.github.io/mithril-ui-kit/",
  "bugs": {
    "url": "https://github.com/14e28f87/mithril-ui-kit/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./components": {
      "import": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && npm run copy-styles",
    "copy-styles": "tsx scripts/copy-styles.ts",
    "watch": "tsc --watch",
    "dev": "npm run watch",
    "docs:dev": "vitepress dev docs --host --port 6172",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --host --port 6172",
    "docs:deploy": "tsx scripts/deploy-docs.ts"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "animate.css": "^4.1.1",
    "bootstrap-icons": "^1.13.1",
    "classnames": "^2.5.1",
    "eventemitter3": "^5.0.4",
    "gridstack": "^12.6.0",
    "lodash-es": "^4.18.1",
    "mithril": "^2.3.8"
  },
  "devDependencies": {
    "@types/classnames": "^2.3.4",
    "@types/lodash-es": "^4.17.12",
    "@types/mithril": "^2.2.8",
    "@types/node": "^25.6.0",
    "mermaid": "^11.14.0",
    "open": "^11.0.0",
    "sass": "^1.99.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}
